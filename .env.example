# Copia in .env e modifica i valori — non committare mai .env su git!

# ── Flask ────────────────────────────────────────────────────────
SECRET_KEY=cambia-questa-chiave-con-una-stringa-casuale-lunga

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite locale. In produzione puoi usare postgres:
# DATABASE_URL=postgresql://user:pass@localhost/csm
DATABASE_URL=sqlite:///csm.db

# ── Admin (unico) ─────────────────────────────────────────────────
# Genera l'hash con:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('la-tua-password'))"
# Poi incolla il risultato qui sotto.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Fallback solo per sviluppo locale (non usare in produzione):
# ADMIN_PASSWORD=cambia-questa-password

# ── Stripe ────────────────────────────────────────────────────────
# Metti STRIPE_ENABLED=true quando sei pronto ad attivare i pagamenti.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prezzi per notte in centesimi (es. 8000 = €80,00)
STRIPE_PRICE_DOUBLE_CENTS=8000
STRIPE_PRICE_SINGLE_CENTS=6000

# URL base del sito (per i redirect di Stripe e i link nelle email)
# In locale: http://localhost:5000
# In produzione: https://www.complessosanmichele-offida.it
SITE_URL=http://localhost:5000

# ── Email ────────────────────────────────────────────────────────
# Metti MAIL_ENABLED=true quando hai configurato l'SMTP.
# Consigliato: Brevo (ex Sendinblue) — gratuito fino a 300 email/giorno.
#   Registrati su brevo.com → SMTP & API → copia host/porta/credenziali.
MAIL_ENABLED=false
MAIL_FROM=info@complessosanmichele-offida.it
ADMIN_EMAIL=info@complessosanmichele-offida.it

# Brevo (default):
MAIL_SMTP_HOST=smtp.brevo.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=la-tua-email@esempio.it
MAIL_PASSWORD=la-tua-smtp-key-brevo

# Gmail alternativa (meno consigliata per produzione):
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_USERNAME=tuoemail@gmail.com
# MAIL_PASSWORD=app-password-gmail   # genera da: account.google.com → Sicurezza → Password app
